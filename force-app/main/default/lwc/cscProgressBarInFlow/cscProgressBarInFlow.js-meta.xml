<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <!-- Allow the component to be used in Screen Flows -->
        <target>lightning__FlowScreen</target>
        <!-- Allow the component to be used in Experience Builder -->
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
        <!-- Allow the component to be used in other Lightning pages -->
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__FlowScreen">
            <property name="currentStep" type="Integer" label="Current Step" />
            <property name="totalSteps" type="Integer" label="Total Steps" />
        </targetConfig>
         <targetConfig targets="lightningCommunity__Default">
            <property name="currentStep" type="Integer" label="Current Step" />
            <property name="totalSteps" type="Integer" label="Total Steps" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>