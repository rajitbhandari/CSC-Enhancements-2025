<!--
 - Created by vpolavarapu on 9/18/2019.
 - Edited by kperry on 9/19/2019. (indent subtopics and enlarge KA text)
 -->

<aura:component
                controller="CustomArticleViewController"
                implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes" access="global" >
    <aura:attribute type="object" name="ArticlesIdentified" />
    <aura:attribute type="string" name="activeSectionName" />
    <aura:attribute type="Boolean" name="ShowKeyArticle" default="false"/>
    <aura:attribute type="Boolean" name="showModal" default="false"/>
    <aura:attribute type="String" name="modalTopicName"/>
    <aura:attribute type="String" name="modalTopicId"/>
    <aura:attribute type="List" name="modalArticles"/>
    <aura:attribute type="String" name="searchTerm" default=""/>
    <aura:attribute name="currentSort" type="String" default="" />
    <aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    <aura:handler name="destroy" value="{!this}" action="{!c.cleanupModalHandlers}" />
    
    <aura:if isTrue="{!v.ArticlesIdentified}">
        <aura:if isTrue="{!v.ShowKeyArticle}">
            <h2 style="margin-left: 09px;margin-top: 10px;font-size: 12pt;">Key Articles </h2>
            <aura:iteration items="{!v.ArticlesIdentified}" var="parentTopic" >
                <aura:iteration items="{!parentTopic.PriorityArticlesForTheTopic}" var="artcile" >
                    <c:CustomArticle_IndividualRow knowledgeObject = "{!artcile}"/>
                </aura:iteration>
            </aura:iteration>
        </aura:if>
        <!-- Clickable list for modal popup -->
        <div>
            <aura:iteration items="{!v.ArticlesIdentified}" var="parentTopic" >
                <div class="slds-p-vertical_x-small">
                    <a href="javascript:void(0);"
                       class="parent-topic-link"
                       data-topic-id="{!parentTopic.TopicId}"
                       data-topic-name="{!parentTopic.TopicName}"
                       onclick="{!c.handleTopicClick}">
                        {!parentTopic.TopicName}
                    </a>
                </div>
                <aura:iteration items="{!parentTopic.childTopicsAssociated}" var="childTopic" >
                    <div class="slds-p-left_xx-large slds-p-vertical_x-small">
                        <a href="javascript:void(0);"
                           class="child-topic-link"
                           data-topic-id="{!childTopic.TopicId}"
                           data-topic-name="{!childTopic.TopicName}"
                           onclick="{!c.handleChildTopicClick}">
                            {!childTopic.TopicName}
                        </a>
                    </div>
                </aura:iteration>
            </aura:iteration>
        </div>
        <!-- Modal markup for subcomponents/articles -->
        <aura:if isTrue="{!v.showModal}">
            <section role="dialog" tabindex="-1" class="slds-modal slds-fade-in-open">
                <div class="slds-modal__container">
                    <header class="slds-modal__header">
                        <h2 class="slds-modal__title">{!v.modalTopicName}</h2>
                        <aura:if isTrue="{!not(empty(v.modalArticles))}">
                            <div class="slds-text-body_small slds-m-top_x-small" style="font-weight:bold;">{!v.modalArticles.length} Articles</div>
                        </aura:if>
                    </header>
                    <div class="slds-modal__content slds-p-around_medium">
                        <!-- Sort and Search Controls at the Top -->
                        <div class="slds-grid slds-gutters slds-p-bottom_small">
                            <div class="slds-col">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="sortSelect">Sort by</label>
                                    <div class="slds-form-element__control">
                                        <select class="slds-select" id="sortSelect" onchange="{!c.handleSortChange}">
                                            <option value="title">Title</option>
                                            <option value="date">Date</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="slds-col">
                                <div class="slds-form-element">
                                    <label class="slds-form-element__label" for="searchInput">Search</label>
                                    <div class="slds-form-element__control slds-grid">
                                        <input type="text" id="searchInput" class="slds-input" oninput="{!c.handleSearchInput}" placeholder="Search articles..." />
                                        <button class="slds-button slds-button_brand slds-m-left_x-small" onclick="{!c.handleReloadModal}">Clear</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- Article List -->
                        <aura:if isTrue="{!not(empty(v.modalArticles))}">
                            <aura:iteration items="{!v.modalArticles}" var="artcile">
                                <div class="slds-p-vertical_x-small">
                                    <c:CustomArticle_IndividualRow knowledgeObject="{!artcile}" />
                                    <div class="slds-border_bottom slds-m-vertical_small"></div>
                                </div>
                            </aura:iteration>
                        <aura:set attribute="else">
                            <div class="slds-text-color_weak slds-p-vertical_medium slds-align_absolute-center">
                                No articles found.
                            </div>
                        </aura:set>
                        </aura:if>
                    </div>
                    <footer class="slds-modal__footer">
                        <button class="slds-button slds-button_neutral" onclick="{!c.handleCloseModal}">Close</button>
                    </footer>
                </div>
            </section>
            <div class="slds-backdrop slds-backdrop_open"></div>
        </aura:if>
    </aura:if>
    
    
    
</aura:component>